# Privy
# Paste your Privy App ID here.
NEXT_PUBLIC_PRIVY_APP_ID=

# Optional in the current frontend flow.
# If Privy gave you a client ID, paste it here; otherwise leave blank for now.
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# Server-side only. Do not expose this as NEXT_PUBLIC.
# Paste your Privy app secret here.
PRIVY_APP_SECRET=

# Solana
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_WS_URL=wss://api.devnet.solana.com

# World ID
NEXT_PUBLIC_WORLD_APP_ID=
NEXT_PUBLIC_WORLD_RP_ID=
NEXT_PUBLIC_WORLD_ENVIRONMENT=staging
NEXT_PUBLIC_WORLD_PILOT_ACTION=shadowpilot-pilot-human-proof
WORLD_RP_SIGNING_KEY=
